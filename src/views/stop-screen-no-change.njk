{% extends "layout.njk" %}

{% set pageTitle = i18n.stopPage.title %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <h1 class="govuk-heading-l">{{ i18n.stopPage.title }}</h1>

        <p class="govuk-body">{{ i18n.stopPage.needTo }}</p>

        <div class="govuk-button-group govuk-!-margin-top-6">
            {{ govukButton({
                text: i18n.stopPage.buttonUpdate,
                href: props.data.updatePartnerDetailsLink,
                attributes: {
                    "id": "update-partner-details-button",
                    "data-event-id": props.data.pageType + "-update-partner-details-button"
                }
            }) }}

            <a class="govuk-link" href={{ props.data.goBackRegisterLink }}>{{ i18n.stopPage.buttonBackRegister }}</a>
        </div>

    </div>
  </div>
{% endblock %}