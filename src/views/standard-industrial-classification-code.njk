{% extends "layout.njk" %}

{% set pageTitle = i18n.sicCodes.title %}
{% set publicRegisterInformationLine1 = i18n.sicCodes.publicRegisterLine1 %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "includes/errors.njk" %}

      {% include "includes/proposed-name.njk" %} 

      <h1 class="govuk-heading-xl">{{ i18n.sicCodes.title }}</h1>

      <p class="govuk-hint" id="sic-hint">{{ i18n.sicCodes.hint }}</p>
      <p class="govuk-!-margin-bottom-6">
        <a href="{{ i18n.sicCodes.findUrl }}" class="govuk-link govuk-link--no-visited-state govuk-body-m" rel="noreferrer noopener" target="_blank">{{ i18n.sicCodes.sicCodePage.find }}</a>
      </p>

      {% set sicCodesList = SET_SIC_CODES_LIST(i18n) %}

      <form method="POST">
        <input type="hidden" name="pageType" value={{ props.pageType }}>
        {% include "includes/csrf_token.njk" %}

        {% if props.data.sicCodes.length > 0 %}
          <div class="govuk-summary-list" role="list">
            {% for sic in props.data.sicCodes %}
                <div class="govuk-summary-list__row">
                  <div class="govuk-summary-list__key">{{ sic.code }}</div>
                  <div class="govuk-summary-list__value">{{ sic.description }}</div>
                  <div class="govuk-summary-list__actions">
                    {{ govukButton({
                      text: i18n.sicCodes.removeButton,
                      name: "action_remove",
                      value: sic.code,
                      classes: "govuk-button--secondary", 
                      attributes: {
                        id: "remove-sic-code-button",
                        type: "submit",
                        "data-event-id": "remove-sic-code-button"
                      }
                    }) }}
                  </div>
                </div>
            {% endfor %}
          </div>
        {% endif %}
            
        {% if props.data.isShowingAddSection %}
          <div class="govuk-inset-text">
            <div class="govuk-form-group govuk-!-margin-bottom-6">
              <label class="govuk-label govuk-label--m" for="sic-code-input">
                {{ i18n.sicCodes.addTitle }}
              </label>

              <div id="sic-hint" class="govuk-hint">
                {{ i18n.sicCodes.addHint }}
              </div>

              <div class="govuk-form-group govuk-form-group--error">
                {% if props.errors.sic_codes %}
                  <span class="govuk-error-message">
                    {{ props.errors.sic_codes.text }}
                  </span>
                {% endif %}
              </div>

              {{ govukInput({
                id: "sic-code-input",
                name: "codeToAdd",
                type: "text",
                classes: "govuk-!-width-full",
                describedBy: "sic-hint",
                label: {
                  text: i18n.sicCodes.addTitle,
                  classes: "govuk-visually-hidden"
                },
                attributes: {
                  placeholder: "Search by SIC code or description",
                  list: "sic-codes"
                }
              }) }}

              <datalist id="sic-codes">
                {% for sic in sicCodesList %}
                  <option value="{{ sic.value }}" label="{{ sic.text }}"></option>
                {% endfor %}
              </datalist>
            </div>

            {{ govukButton({
              text: i18n.sicCodes.addButton,
              name: "action_add",
              value: "true",
              classes: "govuk-button--secondary", 
              attributes: {
                id: "add-sic-code-button",
                type: "submit",
                "data-event-id": "add-sic-code-button"
              }
            }) }}
          </div>
        {% endif %}

        {{ govukDetails({
            summaryText: i18n.sicCodes.expander.title,
            html: 
              '<p class="govuk-body">' + i18n.sicCodes.expander.paragraph1 | escape + '</p>' +
              '<p class="govuk-body">' + i18n.sicCodes.expander.paragraph2 | escape + '</p>' +
              '<p class="govuk-body">' + i18n.sicCodes.expander.paragraph3Start | escape +
                '<a class="govuk-link" href="https://resources.companieshouse.gov.uk/sic/" target="_blank" data-event-id="select-sic-codes-list-link">' + i18n.sicCodes.expander.paragraph3Link | escape + '</a>' +
                i18n.sicCodes.expander.paragraph3End | escape +
              '</p>',
            attributes: {
              "data-event-id": "select-what-are-sic-codes-info"
            }
        }) }}

        {% include "includes/save-and-continue-button.njk" %}
      </form>    
    </div>
  </div>
{% endblock %}
