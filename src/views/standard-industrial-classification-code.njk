{% extends "layout.njk" %}

{% set pageTitle = i18n.sicCodePage.title %}
{% set publicRegisterInformationLine1 = i18n.sicCodePage.publicRegisterLine1 %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "includes/errors.njk" %}

      {% include "includes/proposed-name.njk" %} 

      <h1 class="govuk-heading-xl">{{ i18n.sicCodePage.title }}</h1>

      <p class="govuk-hint" id="sic-hint">{{ i18n.sicCodePage.hint }}</p>
      <p class="govuk-!-margin-bottom-6"><a href="{{ i18n.sicCodePage.findUrl }}" class="govuk-link govuk-link--no-visited-state govuk-body-m" rel="noreferrer noopener" target="_blank">{{ i18n.sicCodePage.find }}</a>.</p>


      {% set summaryDetail %}
        <p class="govuk-body">{{ i18n.SICCSWhatIsDetailExpanderParagraph1 }}</p>
        <p class="govuk-body">{{ i18n.SICCSWhatIsDetailExpanderParagraph2 }}</p>
        <p class="govuk-body">
          {{ i18n.SICCSWhatIsDetailExpanderParagraph3Start }}
          <a class="govuk-link" href="https://resources.companieshouse.gov.uk/sic/" target="_blank" data-event-id="select-sic-codes-list-link">{{ i18n.SICCSWhatIsDetailExpanderParagraph3Link }}</a>
          {{ i18n.SICCSWhatIsDetailExpanderParagraph3End }}
        </p>
      {% endset %}

      {% set sicCodesList = SET_SIC_CODES_LIST(i18n) %}

      <form method="POST">
        <input type="hidden" name="pageType" value={{ props.pageType }}>
        {% include "includes/csrf_token.njk" %}

        {% if props.data.sicCodes.length > 0 %}
          <div class="govuk-summary-list" role="list">
            {% for sic in props.data.sicCodes %}
                <div class="govuk-summary-list__row">
                  <div class="govuk-summary-list__key">{{ sic.code }}</div>
                  <div class="govuk-summary-list__value">{{ sic.description }}</div>
                  <div class="govuk-summary-list__actions">
                    {{ govukButton({
                      text: i18n.sicCodes.SICCSTableRemoveButton,
                      name: "action_remove",
                      value: sic.code,
                      classes: "govuk-button--secondary", 
                      attributes: {
                        id: "remove-sic-code-button",
                        type: "submit",
                        "data-event-id": "remove-sic-code-button"
                      }
                    }) }}
                  </div>
                </div>
            {% endfor %}
          </div>
        {% elif displayRemovedAllSicCodes %}
          <div>
            <p class="govuk-body">
              <strong>{{ i18n.sicCodes.SICCSRemovedAllCodes }}</strong>
            </p>
          </div>
        {% else %}  
          <div>
            <p class="govuk-body">
              <strong>{{ i18n.sicCodes.SICCSNoSICCodeParagraph1 }}</strong>
            </p>
            <p class="govuk-body">
              <strong>{{ i18n.sicCodes.SICCSNoSICCodeParagraph2 }}</strong>
            </p>
          </div>
        {% endif %}
            
        {% if props.data.isShowingAddSection %}
          <div class="govuk-inset-text">
            <div class="govuk-form-group govuk-!-margin-bottom-6">
              <label class="govuk-label govuk-label--m" for="sic-code-input">
                {{ i18n.sicCodes.SICCSAddSICInsetTitle }}
              </label>
              <div id="sic-hint" class="govuk-hint">
                {{ i18n.sicCodes.SICCSAddSICInsetInstructions }}
              </div>
              <div class="govuk-form-group govuk-form-group--error">
                {% if errors %}
                  <span class="govuk-error-message">
                    <span class="govuk-visually-hidden">Error:</span> {{ errors[0].text }}
                  </span>
                {% endif %}
              </div>
              <div id="sic-code-autocomplete"></div>

              <input
                class="govuk-input govuk-!-width-full"
                id="sic-code-input"
                placeholder="Search by SIC code or description"
                name="codeToAdd"
                type="text"
                list="sic-codes"
                aria-describedby="sic-hint"
              />

              <datalist id="sic-codes">
                {% for sic in sicCodesList %}
                  <option value="{{ sic.value }}" label="{{ sic.text }}"></option>
                {% endfor %}
              </datalist>

              {% if unsavedCodeList.length > 0 %}
                <input
                  type="hidden"
                  name="unsavedCodeList"
                  id="unsavedCodeList"
                  value="{{ unsavedCodeList | join(',') }}"
                />
              {% endif %}
            </div>

            {{ govukButton({
              text: i18n.sicCodes.SICCSAddSICAddCodeButton,
              name: "action_add",
              value: "true",
              classes: "govuk-button--secondary", 
              attributes: {
                id: "add-sic-code-button",
                type: "submit",
                "data-event-id": "add-sic-code-button"
              }
            }) }}
          </div>
        {% endif %}

        {{ govukDetails({
            summaryText: i18n.sicCodes.SICCSWhatIsDetailExpanderTitle,
            html: summaryDetail,
            attributes: {
              "data-event-id": "select-what-are-sic-codes-info"
            }
        }) }}

        {% include "includes/save-and-continue-button.njk" %}
      </form>    
    </div>
  </div>
{% endblock %}
