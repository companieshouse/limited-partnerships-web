{% extends "layout.njk" %}

{% set pageTitle = i18n.partnershipTypePage.title %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "includes/errors.njk" %}

      <form class="form" method="post">
        <input type="hidden" name="pageType" value={{ props.pageType }}>

        {% include "includes/csrf_token.njk" %}

        {{ govukRadios({
          classes: "govuk-radios",
          name: "parameter",
          errorMessage: props.errors.parameter if props.errors.parameter,
          fieldset: {
            legend: {
              text: i18n.partnershipTypePage.title,
              isPageHeading: true,
              classes: "govuk-fieldset__legend--xl"
            }
          },
          items: [
            {
              value: "LP",
              text: i18n.types.LP,
              checked: props.data.limitedPartnership.data.partnership_type === "LP",
              attributes: {
                "data-goal-id": PIWIK_REGISTRATION_LP_GOAL_ID
              }
            },
            {
              value: "PFLP",
              text: i18n.types.PFLP,
              checked: props.data.limitedPartnership.data.partnership_type === "PFLP",
              attributes: {
                "data-goal-id": PIWIK_REGISTRATION_PRIVATE_FUND_LP_GOAL_ID
              }
            },
            {
              value: "SLP",
              text: i18n.types.SLP,
              checked: props.data.limitedPartnership.data.partnership_type === "SLP",
              attributes: {
                "data-goal-id": PIWIK_REGISTRATION_SCOTTISH_LP_GOAL_ID
              }
            },
            {
              value: "SPFLP",
              text: i18n.types.SPFLP,
              checked: props.data.limitedPartnership.data.partnership_type === "SPFLP",
              attributes: {
                "data-goal-id": PIWIK_REGISTRATION_SCOTTISH_PRIVATE_FUND_LP_GOAL_ID
              }
            }
          ]
        }) }}

        <button class="govuk-button" data-module="govuk-button" id="submit" onclick="const selected = document.querySelector('input[name=parameter]:checked'); if (selected) { _paq.push(['trackGoal', selected.getAttribute('data-goal-id')]); }">
          {{ i18n.buttons.continue }}
        </button>

      </form>
    </div>
  </div>

{% endblock %}