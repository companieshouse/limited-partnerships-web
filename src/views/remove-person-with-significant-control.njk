{% extends "layout.njk" %}

{% set pageTitle = i18n.personWithSignificantControl.removePscPage.title %}

{% set name = "" %}
{% if props.data.personWithSignificantControl.data.forename %}
  {% set name = props.data.personWithSignificantControl.data.forename + " " + props.data.personWithSignificantControl.data.surname %}
{% elif props.data.personWithSignificantControl.data.legal_entity_name %}
  {% set name = props.data.personWithSignificantControl.data.legal_entity_name %}
{% endif %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% include "includes/errors.njk" %}

      <form class="form" method="post">
        <input type="hidden" name="pageType" value={{ props.pageType }}>

        {% include "includes/csrf_token.njk" %}

        {{ govukRadios({
            classes: "govuk-radios--inline",
            idPrefix: "remove",
            name: "remove",
            fieldset: {
                legend: {
                    text: pageTitle + " " + name + "?",
                    isPageHeading: true,
                    classes: "govuk-fieldset__legend--l"
                }
            },
            items: [
                {
                    value: "yes",
                    text: i18n.yesAndNo.yes
                },
                {
                    value: "no",
                    text: i18n.yesAndNo.no
                }
            ],
            errorMessage: {
                text: i18n.personWithSignificantControl.removePscPage.errorMessage
            } if props.errors
        }) }}

        {{ govukButton({
            text: i18n.buttons.saveAndContinue,
            attributes: {
                "id": "submit",
                "onclick": "_paq.push(['trackEvent', 'Limited Partnerships', 'Are you sure you want to remove PSC', document.querySelector('input[name=remove]:checked').nextElementSibling.innerHTML])"
            }
        }) }}
      </form>
    </div>
  </div>

{% endblock %}
